	<parameter name="idPaoSeleccionado" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\ENVY360\\Desktop\\Manuel\\Desarrollo\\Fase2\\BankSys-web\\src\\java\\com\\coop1\\soficoop\\pln\\reportes\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ag.NOMBRE AS AGENCIA, re.CODEMP, gp.NOMCOM, dp.DESCDEPTO,
    pe.DESCRIP AS PEP, p.NOMBREPAO, p.ANIO, pe.ANIOINI || '- ' || pe.ANIOFIN AS VIGENCIA,
    m.NOMBRE AS PERSPECTIVA,
    oe.CODIGOOE || ': ' || oe.DESCRIP AS OBJETIVO_ESTRATEGICO,
    ind.CODIGOINDICADOR || ': ' || ind.DESCRIP AS INDICADOR_CUMPLIMIENTO,
    le.DESCRIP AS ESTRATEGIA, ini.DESCRIP AS INICIATIVA,
    a.IDACCIONPAO AS ID_ACCION, a.DESCRIP AS ACCION_A_REALIZAR,
    NVL((SELECT MAX(CUMPLIPCT) FROM PLNACCIONEVAL e WHERE e.IDACCIONPAO = a.IDACCIONPAO), 0) AS AVANCE,
    a.MEDIOVERIFI AS MEDIO_VERIFICACION,
    NVL(tm.ACTIVIPROGRA, 'Sin planificación trimestral') AS ACTIVIDAD,
    NVL(tm.MESINI, 0) AS MESINI, NVL(tm.MESFIN, 0) AS MESFIN
FROM PLNACCIONDETA a
    JOIN PLNPAO p ON a.IDPAO = p.IDPAO
    JOIN PLNPEP pe ON p.IDPEP = pe.IDPEP
    JOIN RHUEMPLEADOS re ON p.IDCOORDINADOR = re.CODEMP
    JOIN GENPERSONAS gp ON re.CODEMP = gp.CODPER
    JOIN RHUPUESTOS pu ON re.CODPUESTO = pu.CODPUESTO
    LEFT JOIN RHUDEPTOS dp ON pu.CODDEPTO = dp.CODDEPTO
    LEFT JOIN GENAGENCIAS ag ON re.CODAGEN = ag.CODAGEN
    JOIN PLNPEPLINESTR le ON a.IDESTRATEGIA = le.IDESTRATEGIA
    JOIN PLNPEPINDICUMPL ind ON le.IDINDICADORCUMP = ind.IDINDICADORCUMP
    JOIN PLNPEPOBJETIVO oe ON ind.IDOBJETIVO = oe.IDOBJETIVO
    JOIN PLNPERSPECTIVADETA pd ON oe.IDPERSPECTIVA = pd.IDPERSPECTIVA
    JOIN PLNPERSPECTIVA m ON pd.IDMAESTRO = m.IDMAESTRO
    JOIN PLNPAOINICDETA inid ON inid.IDACCIONPAO = a.IDACCIONPAO
    JOIN PLNPAOINIC ini ON ini.IDINICIATIVA = inid.IDINICIATIVA
    LEFT JOIN PLNACCIDETPLANTRIM tm ON a.IDACCIONPAO = tm.IDACCIONPAO
WHERE p.IDPAO = $P{idPaoSeleccionado} AND dp.DESCDEPTO IS NOT NULL
ORDER BY m.NOMBRE, ini.DESCRIP, le.DESCRIP, a.IDACCIONPAO, tm.MESINI]]>
	</queryString>
