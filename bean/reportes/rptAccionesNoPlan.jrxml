	<property name="ireport.zoom" value="2.3579476910000396"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idPaoSeleccionado" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT
    pep.DESCRIP AS PEP_DESC,
    per.NOMBRE AS PERSPECTIVA,
    oe.CODIGOOE || ': ' || oe.DESCRIP AS OBJETIVO,
    ind.CODIGOINDICADOR || ': ' || ind.DESCRIP AS INDICADOR,
    lin.DESCRIP AS ESTRATEGIA,
    pao.NOMBREPAO,
    sinp.DESCRIP AS ACCION_EXTRA,
    sinp.CUMPLIPCT,
    sinp.PERIEVAL,
    sinp.PROYEC,
    sinp.REALIZ,
    sinp.OBSERV
FROM PLNPEP pep
JOIN PLNPERSPECTIVADETA pers ON pep.IDPEP = pers.IDPEP
JOIN PLNPERSPECTIVA per ON per.IDMAESTRO = pers.IDMAESTRO
JOIN PLNPEPOBJETIVO oe ON pers.IDPERSPECTIVA = oe.IDPERSPECTIVA
JOIN PLNPEPINDICUMPL ind ON oe.IDOBJETIVO = ind.IDOBJETIVO
JOIN PLNPEPLINESTR lin ON ind.IDINDICADORCUMP = lin.IDINDICADORCUMP
JOIN PLNACCIONSINPLAN sinp ON lin.IDESTRATEGIA = sinp.IDESTRATEGIA
JOIN PLNPAO pao ON sinp.IDPAO = pao.IDPAO
WHERE pao.IDPAO = $P{idPaoSeleccionado}
ORDER BY per.NOMBRE, oe.CODIGOOE, ind.CODIGOINDICADOR, lin.DESCRIP]]>
	</queryString>
