				<reportElement uuid="f553c506-62c6-46d3-8bcd-aa066ddb97a1" stretchType="RelativeToTallestObject" mode="Transparent" x="638" y="0" width="93" height="34" forecolor="#000000" backcolor="#FFFFFF"/>
				<box>
					<pen lineWidth="0.5" lineColor="#CCCCCC"/>
