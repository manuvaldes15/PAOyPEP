<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptPlaneacionPAO" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="122f0d35-562c-4d8c-a47a-7f3c71a64898">
	<property name="ireport.zoom" value="1.7715610000000155"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="1"/>
	<parameter name="idPaoSeleccionado" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\ENVY360\\Desktop\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH BASE_ACCIONES AS (
    SELECT
        A.IDPAO,
        A.IDESTRATEGIA,
        'PLANIFICADA'       AS ORIGEN,
        NVL(E.CUMPLIPCT, 0) AS PORCENTAJE
    FROM PLNACCIONDETA A
    LEFT JOIN (
        SELECT IDACCIONPAO, MAX(CUMPLIPCT) AS CUMPLIPCT
        FROM PLNACCIONEVAL
        GROUP BY IDACCIONPAO
    ) E ON A.IDACCIONPAO = E.IDACCIONPAO
    WHERE A.IDPAO = $P{idPaoSeleccionado}
    UNION ALL
    SELECT
        NP.IDPAO,
        NP.IDESTRATEGIA,
        'NO PLANIFICADA'    AS ORIGEN,
        NVL(NP.CUMPLIPCT, 0) AS PORCENTAJE
    FROM PLNACCIONSINPLAN NP
    WHERE NP.IDPAO = $P{idPaoSeleccionado}
),
BASE_JERARQUIA AS (
    SELECT
        BA.ORIGEN,
        BA.PORCENTAJE,
        IND.IDINDICADORCUMP,
        OE.IDOBJETIVO,
        OE.CODIGOOE,
        OE.DESCRIP AS NOMBRE_OE,
        PD.IDPERSPECTIVA,
        M.IDMAESTRO,
        M.NOMBRE AS PERSPECTIVA
    FROM BASE_ACCIONES BA
    INNER JOIN PLNPEPLINESTR LE  ON BA.IDESTRATEGIA = LE.IDESTRATEGIA
    INNER JOIN PLNPEPINDICUMPL IND ON LE.IDINDICADORCUMP = IND.IDINDICADORCUMP
    INNER JOIN PLNPEPOBJETIVO OE  ON IND.IDOBJETIVO = OE.IDOBJETIVO
    INNER JOIN PLNPERSPECTIVADETA PD ON OE.IDPERSPECTIVA = PD.IDPERSPECTIVA
    INNER JOIN PLNPERSPECTIVA M   ON PD.IDMAESTRO = M.IDMAESTRO
),
NIVEL_OE AS (
    SELECT
        IDMAESTRO,
        PERSPECTIVA,
        IDOBJETIVO,
        CODIGOOE,
        NOMBRE_OE,
        COUNT(*) AS TOTAL_ACCIONES,
        COUNT(CASE WHEN ORIGEN = 'PLANIFICADA' THEN 1 END) AS ACC_PLAN,
        COUNT(CASE WHEN ORIGEN = 'PLANIFICADA' AND PORCENTAJE > 0 THEN 1 END) AS ACC_PLAN_EVALUADAS,
        COUNT(CASE WHEN ORIGEN = 'NO PLANIFICADA' THEN 1 END) AS ACC_NO_PLAN,
        COUNT(CASE WHEN ORIGEN = 'NO PLANIFICADA' AND PORCENTAJE > 0 THEN 1 END) AS ACC_NO_PLAN_EVALUADAS,
        COUNT(CASE WHEN PORCENTAJE > 0 THEN 1 END) AS ACC_EVALUADAS_TOTAL,
        ROUND(AVG(CASE WHEN ORIGEN = 'PLANIFICADA' THEN PORCENTAJE END), 2) AS CUMPLI_PLAN,
        ROUND(AVG(CASE WHEN ORIGEN = 'NO PLANIFICADA' THEN PORCENTAJE END), 2) AS CUMPLI_NO_PLAN,
        ROUND(AVG(PORCENTAJE), 2) AS CUMPLI_TOTAL_OE
    FROM BASE_JERARQUIA
    GROUP BY IDMAESTRO, PERSPECTIVA, IDOBJETIVO, CODIGOOE, NOMBRE_OE
),
NIVEL_PERSPECTIVA AS (
    SELECT
        n.*,
        ROUND(AVG(CUMPLI_TOTAL_OE) OVER (PARTITION BY IDMAESTRO), 2) AS CUMPLI_PERSPECTIVA_VAL
    FROM NIVEL_OE n
)
SELECT
    PERSPECTIVA,
    CODIGOOE,
    NOMBRE_OE,
    TOTAL_ACCIONES,
    ACC_PLAN,
    ACC_PLAN_EVALUADAS,
    ACC_NO_PLAN,
    ACC_NO_PLAN_EVALUADAS,
    ACC_EVALUADAS_TOTAL,
    NVL(CUMPLI_PLAN, 0) AS CUMPLI_PLAN,
    NVL(CUMPLI_NO_PLAN, 0) AS CUMPLI_NO_PLAN,
    NVL(CUMPLI_TOTAL_OE, 0) AS CUMPLI_TOTAL_OE,
    -- Cumplimiento de Perspectiva heredado del paso anterior
    NVL(CUMPLI_PERSPECTIVA_VAL, 0) AS CUMPLI_PERSPECTIVA,
    NVL(ROUND((SELECT AVG(CUMPLI_PERSPECTIVA_VAL)
            FROM (SELECT DISTINCT IDMAESTRO, CUMPLI_PERSPECTIVA_VAL FROM NIVEL_PERSPECTIVA)), 2), 0) AS CUMPLI_GLOBAL_PAO
FROM NIVEL_PERSPECTIVA
ORDER BY PERSPECTIVA, CODIGOOE]]>
	</queryString>
	<field name="PERSPECTIVA" class="java.lang.String"/>
	<field name="CODIGOOE" class="java.lang.String"/>
	<field name="NOMBRE_OE" class="java.lang.String"/>
	<field name="TOTAL_ACCIONES" class="java.math.BigDecimal"/>
	<field name="ACC_PLAN" class="java.math.BigDecimal"/>
	<field name="ACC_PLAN_EVALUADAS" class="java.math.BigDecimal"/>
	<field name="ACC_NO_PLAN" class="java.math.BigDecimal"/>
	<field name="ACC_NO_PLAN_EVALUADAS" class="java.math.BigDecimal"/>
	<field name="ACC_EVALUADAS_TOTAL" class="java.math.BigDecimal"/>
	<field name="CUMPLI_PLAN" class="java.math.BigDecimal"/>
	<field name="CUMPLI_NO_PLAN" class="java.math.BigDecimal"/>
	<field name="CUMPLI_TOTAL_OE" class="java.math.BigDecimal"/>
	<field name="CUMPLI_PERSPECTIVA" class="java.math.BigDecimal"/>
	<field name="CUMPLI_GLOBAL_PAO" class="java.math.BigDecimal"/>
