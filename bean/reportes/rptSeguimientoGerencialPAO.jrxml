<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptSeguimientoGerencialPAO" pageWidth="612" pageHeight="792" whenNoDataType="AllSectionsNoDetail" columnWidth="572" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c3f5f091-7e2e-420d-96b7-5de83c26a7fe">
	<property name="ireport.zoom" value="2.6573415000000047"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idPao" class="java.lang.Integer"/>
	<parameter name="perievalFiltro" class="java.lang.String">
		<parameterDescription><![CDATA[Periodo a filtrar]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
            se.IDSEGUIMIENTO,
            se.ESTADO,
            se.ACCIREQUE,
            se.COMPROMISO,
            se.FCHACREA,
            NVL(ev.PERIEVAL, 'Sin Período') AS PERIEVAL,
            NVL(ev.CUMPLIPCT, 0) AS CUMPLIPCT,
            acc.DESCRIP AS ACCION_DESCRIP,
            pa.NOMBREPAO,
            pa.ANIO,
            pep.DESCRIP AS NOMBRE_PEP,
            pep.ANIOINI || ' - ' || pep.ANIOFIN AS VIGENCIA_PEP
        FROM COOPONEDS.PLNACCIONSEGUIMIENTO se
        INNER JOIN COOPONEDS.PLNACCIONDETA acc ON se.IDACCIONPAO = acc.IDACCIONPAO
        INNER JOIN COOPONEDS.PLNPAO pa ON acc.IDPAO = pa.IDPAO
        INNER JOIN COOPONEDS.PLNPEP pep ON pa.IDPEP = pep.IDPEP
        LEFT JOIN COOPONEDS.PLNACCIONEVAL ev ON acc.IDACCIONPAO = ev.IDACCIONPAO
        WHERE pa.IDPAO = $P{idPao}
          AND (
              $P{perievalFiltro} IS NULL OR $P{perievalFiltro} = '' OR $P{perievalFiltro} = '0'
              OR
              (CASE ev.PERIEVAL
                  WHEN 'ENERO - MARZO' THEN 1
                  WHEN 'ENERO - JUNIO' THEN 2
                  WHEN 'ENERO - SEPTIEMBRE' THEN 3
                  WHEN 'ENERO - DICIEMBRE' THEN 4
                  ELSE 5
              END)
              <=
              (CASE $P{perievalFiltro}
                  WHEN 'ENERO - MARZO' THEN 1
                  WHEN 'ENERO - JUNIO' THEN 2
                  WHEN 'ENERO - SEPTIEMBRE' THEN 3
                  WHEN 'ENERO - DICIEMBRE' THEN 4
                  ELSE 0
              END)
          )
        ORDER BY NVL(ev.PERIEVAL, 'Sin Período') ASC, acc.DESCRIP ASC, se.FCHACREA DESC]]>
	</queryString>
