<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SubRptPep" language="groovy" pageWidth="802" pageHeight="160" orientation="Landscape" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="de07c7a7-808c-49fe-9e60-62a5b5ee9ab6">
	<property name="ireport.zoom" value="2.143588810000017"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idPepSeleccionado" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="anio" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    pe.DESCRIP AS NOMBRE_PEP,
    pe.ANIOINI || ' - ' || pe.ANIOFIN AS VIGENCIA,
    COUNT(DISTINCT pd.IDMAESTRO) AS TOTAL_PERSPECTIVAS,
    COUNT(DISTINCT oe.IDOBJETIVO) AS TOTAL_OBJETIVOS,
    COUNT(DISTINCT ind.IDINDICADORCUMP) AS TOTAL_INDICADORES,
    COUNT(DISTINCT le.IDESTRATEGIA) AS TOTAL_LINEAS_ESTRATEGICAS
FROM PLNPEP pe
JOIN PLNPERSPECTIVADETA pd ON pe.IDPEP = pd.IDPEP
LEFT JOIN PLNPEPOBJETIVO oe ON pd.IDPERSPECTIVA = oe.IDPERSPECTIVA
LEFT JOIN PLNPEPINDICUMPL ind ON oe.IDOBJETIVO = ind.IDOBJETIVO
LEFT JOIN PLNPEPLINESTR le ON ind.IDINDICADORCUMP = le.IDINDICADORCUMP
WHERE pe.IDPEP =  $P{idPepSeleccionado}
GROUP BY pe.DESCRIP, pe.ANIOINI, pe.ANIOFIN]]>
	</queryString>
	<field name="NOMBRE_PEP" class="java.lang.String"/>
	<field name="VIGENCIA" class="java.lang.String"/>
	<field name="TOTAL_PERSPECTIVAS" class="java.math.BigDecimal"/>
	<field name="TOTAL_OBJETIVOS" class="java.math.BigDecimal"/>
	<field name="TOTAL_INDICADORES" class="java.math.BigDecimal"/>
	<field name="TOTAL_LINEAS_ESTRATEGICAS" class="java.math.BigDecimal"/>
