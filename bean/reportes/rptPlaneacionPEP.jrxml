	</parameter>
	<parameter name="lineaAnio" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    pe.IDPEP, pe.DESCRIP AS NOMBRE_PEP, pe.ANIOINI AS ANIO_INICIO, pe.ANIOFIN AS ANIO_FIN,
    m.NOMBRE AS PERSPECTIVA,
    oe.CODIGOOE AS COD_OBJETIVO, oe.DESCRIP AS OBJETIVO_ESTRATEGICO,
    ind.CODIGOINDICADOR AS COD_INDICADOR, ind.DESCRIP AS INDICADOR_CUMPLIMIENTO,
    le.IDESTRATEGIA, le.DESCRIP AS LINEA_ESTRATEGICA, le.ANIO AS ANIO_ESTRATEGIA
FROM PLNPEP pe
JOIN PLNPERSPECTIVADETA pd ON pe.IDPEP = pd.IDPEP
JOIN PLNPERSPECTIVA m ON pd.IDMAESTRO = m.IDMAESTRO
LEFT JOIN PLNPEPOBJETIVO oe ON pd.IDPERSPECTIVA = oe.IDPERSPECTIVA
LEFT JOIN PLNPEPINDICUMPL ind ON oe.IDOBJETIVO = ind.IDOBJETIVO
LEFT JOIN PLNPEPLINESTR le ON ind.IDINDICADORCUMP = le.IDINDICADORCUMP
WHERE pe.IDPEP = $P{idPepSeleccionado}
  AND ($P{lineaAnio} IS NULL OR le.ANIO = $P{lineaAnio})
ORDER BY pe.IDPEP, m.NOMBRE, oe.CODIGOOE, ind.CODIGOINDICADOR, le.IDESTRATEGIA]]>
	</queryString>
	<field name="IDPEP" class="java.math.BigDecimal"/>
	<field name="NOMBRE_PEP" class="java.lang.String"/>
	<field name="ANIO_INICIO" class="java.math.BigDecimal"/>
	<field name="ANIO_FIN" class="java.math.BigDecimal"/>
