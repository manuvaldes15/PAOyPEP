	<field name="IDESTRATEGIA" class="java.math.BigDecimal"/>
	<field name="LINEA_ESTRATEGICA" class="java.lang.String"/>
	<field name="ANIO_ESTRATEGIA" class="java.math.BigDecimal"/>
